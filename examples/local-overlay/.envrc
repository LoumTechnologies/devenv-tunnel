# direnv snippet for the local-overlay example.
#
# This exports DEVENV_TUNNEL with a full `.devenv.local` domain BEFORE any
# process starts, which is exactly what the daemon needs (it reads the frozen
# execve() environment via /proc/<pid>/environ).
#
# Run `direnv allow` in this directory to activate it, then start the service
# with `python3 server.py`.
#
# The `.devenv.local` suffix selects the LOCAL virtual overlay path (vs.
# `.tunnel.devenv.tools` for the cloud tunnel). Nothing is appended implicitly.

# A trailing `:<port>` declares the CANONICAL port the overlay exposes the
# service on (`VIP:8080`), proxying to the real ephemeral backend. Without it
# the overlay would expose the discovered ephemeral port instead, forcing
# clients to use that random number.
export DEVENV_TUNNEL="hello.devenv.local:8080"

# Branch-templated variant (uncomment to use a per-branch name instead):
# export DEVENV_TUNNEL="hello-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown).devenv.local:8080"
