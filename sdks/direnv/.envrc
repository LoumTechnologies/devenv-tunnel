# devenv-tunnel — direnv integration
#
# Add this block to your project's .envrc to automatically export DEVENV_TUNNEL
# based on the current git branch. direnv re-sources .envrc whenever you cd
# into the directory, so the variable is always set before your process starts.
#
# This is the PRIMARY recommended way to set DEVENV_TUNNEL. Because the
# devenv-tunnel daemon reads each process's environment from /proc/<pid>/environ
# (Linux) or sysctl KERN_PROCARGS2 (macOS) — both frozen at execve() time —
# the variable MUST be present in the environment before the process launches.
#
# Usage:
#   1. Copy this file to your project root as .envrc, or append the lines
#      below to your existing .envrc.
#   2. Run: direnv allow
#   3. Start your server normally — DEVENV_TUNNEL will already be set.
#
# Customise the domain template to match your project:
#   - Replace "myapp" with your service name.
#   - Use ".devenv.local" suffix for the local virtual overlay.
#   - Use ".tunnel.devenv.tools" suffix for the cloud tunnel.

# Resolve the current git branch (falls back to "unknown" when not in a repo).
_DEVENV_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"

# Local virtual overlay (resolves {branch} here in the shell, before exec):
export DEVENV_TUNNEL="myapp-${_DEVENV_BRANCH}.devenv.local"

# Uncomment for cloud tunnel instead:
# export DEVENV_TUNNEL="myapp-${_DEVENV_BRANCH}.tunnel.devenv.tools"

unset _DEVENV_BRANCH
